# DropRoom Backend Environment Variables

# Server Configuration
NODE_ENV=production
PORT=3000

# CORS Configuration (your frontend domain)
FRONTEND_URL=https://yourusername.github.io/DropRoom

# File Upload Configuration
MAX_FILE_SIZE=524288000  # 500MB in bytes

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-droproom-bucket-name

# Storage Configuration
STORAGE_TYPE=s3  # 's3' for cloud storage, 'local' for local storage

# Security
SESSION_SECRET=your-secret-key-here

# Optional: Custom domain for backend
BACKEND_URL=https://your-backend-url.onrender.com
