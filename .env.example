# DropRoom Backend Environment Variables

# Server Configuration
NODE_ENV=production
PORT=3000

# CORS Configuration (your frontend domain)
FRONTEND_URL=https://yourusername.github.io/DropRoom

# File Upload Configuration
MAX_FILE_SIZE=524288000  # 500MB in bytes

# Cloudinary Configuration (Easiest Cloud Storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Storage Configuration
STORAGE_TYPE=cloudinary  # 'cloudinary' for cloud storage, 'local' for local storage

# Security
SESSION_SECRET=your-secret-key-here

# Optional: Custom domain for backend
BACKEND_URL=https://your-backend-url.onrender.com
